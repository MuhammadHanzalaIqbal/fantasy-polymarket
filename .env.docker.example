# Fantasy Polymarket - Docker / Sepolia
# Copy to .env and set RPC_URL, PRIVATE_KEY before: docker compose up --build
# Sepolia contract addresses (from README)

APP_NAME="Fantasy Polymarket MVP Backend"
APP_VERSION="0.1.0"
DEBUG=false

RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
CHAIN_ID=11155111
PRIVATE_KEY="0xYOUR_PRIVATE_KEY"
REQUEST_TIMEOUT_SECONDS=30

# Deployed Sepolia addresses
FANTASY_TOKEN_ADDRESS="0x82021CcfED084fD8578cb38d8D4323345C363079"
PLAYER_MARKET_ADDRESS="0x96f1b5Edb7Fed2E3c0BD09C22b289409BC6BfFEa"
CONTEST_MANAGER_ADDRESS="0x8B7b7b534a3552A8d2Ea0EB91313AA3aF475b47e"
ORACLE_ADAPTER_ADDRESS="0x62Fe83664239397d0b6Ea37bcbE1b775520c204c"
PLAYER_SHARE_MANAGER_ADDRESS="0x63Ea24Cd1e2e47D9e57EDdFaB3045E3aA68ca2A5"

DEMO_ADMIN_API_KEY="demo-key"
